{
  "name": "workos",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop command center for machine setup and workspace management.",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5555 && ELECTRON_RUN_AS_NODE= ELECTRON_RENDERER_URL=http://localhost:5555 electron desktop/main.js\"",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "start": "ELECTRON_RUN_AS_NODE= electron desktop/main.js",
    "postinstall": "electron-rebuild -f -o better-sqlite3",
    "reset": "node -e \"const p=require('path'),f=require('fs'),h=require('os').homedir();f.rmSync(p.join(h,'Library/Application Support/workos'),{recursive:true,force:true});console.log('Reset complete.')\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "better-sqlite3": "^12.0.0",
    "concurrently": "^9.2.0",
    "electron": "^41.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  }
}
